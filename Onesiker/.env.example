# ──────────────────────────────────────────────────────────────────────
# FTP credentials for `npm run sync-prod-data` (and `prebuild`).
# Pulls dist/data/*.json from production into public/data/ so a local
# rebuild does not overwrite content edited via the back-office.
#
# Copy to .env and fill in. .env is git-ignored.
# ──────────────────────────────────────────────────────────────────────
FTP_HOST=ftp.cluster001.ovh.net
FTP_USER=
FTP_PASSWORD=
FTP_SECURE=true

# Path on the FTP server containing the JSON data files (without trailing slash).
# Adjust if your OVH hosting puts the public root somewhere other than `www/`.
FTP_REMOTE_DATA_DIR=www/data

# Set to "true" to make build fail when sync errors occur (recommended in CI).
# Defaults to false: the build proceeds with stale local data + a warning.
SYNC_PROD_DATA_STRICT=false

# Set to "true" to skip the sync entirely (useful for offline / first-time setup).
SYNC_PROD_DATA_SKIP=false
