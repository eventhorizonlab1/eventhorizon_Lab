RewriteEngine On

# Bloquer l'accès aux dossiers sensibles (Git, etc.)
RewriteRule ^\.(git|svn|hg|env|htaccess) - [F]

# Désactiver le directory listing global
Options -Indexes

# MIME types — Apache n'a pas .webmanifest dans sa table par défaut.
# Sans cette ligne, le manifest est servi sans Content-Type et certains
# navigateurs ignorent l'app (PWA "Add to Home Screen" cassé).
AddType application/manifest+json .webmanifest

# Forcer le HTTPS (Sécurité)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirection vers index.html pour React (SPA)
RewriteCond %{REQUEST_URI} !^/googleec6c94cc4f4730b6\.html$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# ── COMPRESSION GZIP / DEFLATE ────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json application/manifest+json
    AddOutputFilterByType DEFLATE image/svg+xml application/xml
    AddOutputFilterByType DEFLATE font/woff font/woff2
</IfModule>

# ── CACHE HTTP — PERFORMANCES ─────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # Assets Vite (JS/CSS avec hash dans le nom) → 1 an
    ExpiresByType application/javascript     "access plus 1 year"
    ExpiresByType text/css                   "access plus 1 year"

    # Images → 3 mois
    ExpiresByType image/webp                 "access plus 3 months"
    ExpiresByType image/jpeg                 "access plus 3 months"
    ExpiresByType image/png                  "access plus 3 months"
    ExpiresByType image/gif                  "access plus 3 months"
    ExpiresByType image/svg+xml              "access plus 3 months"

    # Polices → 1 an
    ExpiresByType font/woff                  "access plus 1 year"
    ExpiresByType font/woff2                 "access plus 1 year"

    # JSON (données dynamiques admin) → pas de cache
    ExpiresByType application/json           "access plus 0 seconds"

    # Manifest PWA (rarement modifié) → 1 mois
    ExpiresByType application/manifest+json  "access plus 1 month"

    # HTML → pas de cache (SPA entry point)
    ExpiresByType text/html                  "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # HSTS (Obligatoire pour le Grade A+)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Protection contre le clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Protection contre le reniflage de type MIME
    Header always set X-Content-Type-Options "nosniff"

    # Protection contre le XSS
    Header always set X-XSS-Protection "1; mode=block"

    # Politique de référent
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Politique de permissions navigateur (caméra, micro, géoloc)
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # Cache immuable pour assets hachés Vite (JS/CSS avec hash)
    <FilesMatch "\.[0-9a-f]{8,}\.(js|css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Revalidation systématique mais cache autorisé. `no-cache` (≠ `no-store`)
    # force le navigateur à revalider à chaque requête, tout en restant éligible
    # au back/forward cache (instant restore lors d'un retour arrière).
    <FilesMatch "index\.html$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    # Idem pour les JSON de données (édités via le back-office) :
    # toujours frais, mais bf-cache friendly.
    <FilesMatch "\.json$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    # ── CONTENT SECURITY POLICY — MODE BLOQUANT ───────────────────────────────
    # Validée sans violations en mode Report-Only. Active et bloquante.
    # Si une nouvelle ressource externe est ajoutée au site, la déclarer ici.
    Header always set Content-Security-Policy "\
default-src 'self'; \
script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; \
style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
font-src 'self' https://fonts.gstatic.com; \
img-src 'self' data: https:; \
connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://analytics.google.com; \
frame-src https://www.googletagmanager.com; \
frame-ancestors 'none'; \
object-src 'none'; \
base-uri 'self';"
</IfModule>
